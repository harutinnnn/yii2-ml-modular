Options +FollowSymLinks -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Backend static files under /admin.
    RewriteRule ^admin/assets/(.*)$ backend/web/assets/$1 [L]
    RewriteRule ^admin/css/(.*)$ backend/web/css/$1 [L]
    RewriteRule ^admin/js/(.*)$ backend/web/js/$1 [L]
    RewriteRule ^admin/favicon\.ico$ backend/web/favicon.ico [L]
    RewriteRule ^admin/robots\.txt$ backend/web/robots.txt [L]

    # Frontend static files from the site root.
    RewriteRule ^assets/(.*)$ frontend/web/assets/$1 [L]
    RewriteRule ^css/(.*)$ frontend/web/css/$1 [L]
    RewriteRule ^js/(.*)$ frontend/web/js/$1 [L]
    RewriteRule ^uploads/(.*)$ frontend/web/uploads/$1 [L]
    RewriteRule ^favicon\.ico$ frontend/web/favicon.ico [L]
    RewriteRule ^robots\.txt$ frontend/web/robots.txt [L]

    # Route all application requests through the root dispatcher.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>
